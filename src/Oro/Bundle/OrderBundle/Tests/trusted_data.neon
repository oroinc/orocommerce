# Configuration for https://github.com/oroinc/phpstan-rules/
trusted_data:
    variables:
        Oro\Bundle\OrderBundle\Api\OrderAddressQueryModifier:
            addOrderSubquery:
                addressAlias: true
        Oro\Bundle\OrderBundle\Datagrid\DraftSession\OrderLineItemDraftValidationDatagridListener:
            prependOrderByIsValid:
                orderByDqlPart: true
